# Sprite Generation — API Keys
# The script also checks ../env (gourmet_go/.env) automatically.

# Google Gemini API key — PRIMARY generator
# Model: gemini-2.5-flash-image (override with GEMINI_MODEL)
GEMINI_API_KEY=

# OpenAI API key — FALLBACK (DALL-E 3) when Gemini fails
# Optional — only needed for --use-dalle or as automatic fallback
OPENAI_API_KEY=

# Override Gemini model (optional):
# GEMINI_MODEL=gemini-2.5-flash-image
