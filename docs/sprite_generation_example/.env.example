# Sprite Generation — API Keys
# Copy this file to .env and fill in your keys.

# Google Gemini API key — PRIMARY for sprite generation
# Model: gemini-2.5-flash-image (default). Override with GEMINI_MODEL env var.
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI API key — FALLBACK (DALL-E 3) when Gemini fails
# Get yours at: https://platform.openai.com/api-keys
# Optional — only needed if you use --use-dalle or Gemini fails
OPENAI_API_KEY=

# Override the Gemini model (optional):
# GEMINI_MODEL=gemini-2.5-flash-image
